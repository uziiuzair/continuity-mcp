{
  "mcpServers": {
    "continuity": {
      "command": "node",
      "args": ["--experimental-sqlite", "${CLAUDE_PLUGIN_ROOT}/mcp/index.mjs"],
      "env": {
        "NODE_NO_WARNINGS": "1",
        "CONTINUITY_API_URL": "${user_config.apiUrl}",
        "CONTINUITY_API_KEY": "${user_config.apiKey}",
        "CONTINUITY_REPO_ALLOWLIST": "${user_config.repoAllowlist}",
        "CONTINUITY_DB_PATH": "${user_config.dbPath}"
      }
    }
  }
}
